<footer class="site-footer" role="contentinfo">
  <div class="footer-grid">
    {% comment %} Brand Column {% endcomment %}
    <div class="footer-brand">
      <span class="footer-brand__logo">V E L L A</span>
      <span class="footer-brand__est">EST. 2025</span>
      <div class="gold-line" style="margin: var(--space-md) 0; margin-left: 0;"></div>
      <p class="footer-brand__tagline">The art of understated elegance.</p>
      <div class="footer-social">
        <a href="{{ settings.social_instagram }}" aria-label="Instagram">{% render 'icon', name: 'instagram' %}</a>
        <a href="{{ settings.social_tiktok }}" aria-label="TikTok">{% render 'icon', name: 'tiktok' %}</a>
        <a href="{{ settings.social_pinterest }}" aria-label="Pinterest">{% render 'icon', name: 'pinterest' %}</a>
      </div>
    </div>

    {% comment %} Shop Links {% endcomment %}
    <div class="footer-links">
      <h4 class="footer-links__title">Shop</h4>
      {% for link in section.settings.shop_menu.links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
      {% if section.settings.shop_menu == blank %}
        <a href="/collections/all">All Products</a>
        <a href="/collections">Collections</a>
      {% endif %}
    </div>

    {% comment %} Info Links {% endcomment %}
    <div class="footer-links">
      <h4 class="footer-links__title">Info</h4>
      {% for link in section.settings.info_menu.links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
      {% if section.settings.info_menu == blank %}
        <a href="/pages/about">About</a>
        <a href="/pages/contact">Contact</a>
        <a href="/pages/faq">FAQ</a>
      {% endif %}
    </div>

    {% comment %} Legal Links {% endcomment %}
    <div class="footer-links">
      <h4 class="footer-links__title">Legal</h4>
      {% for link in section.settings.legal_menu.links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
      {% if section.settings.legal_menu == blank %}
        <a href="/policies/shipping-policy">Shipping Policy</a>
        <a href="/policies/refund-policy">Return Policy</a>
        <a href="/policies/privacy-policy">Privacy Policy</a>
        <a href="/policies/terms-of-service">Terms of Service</a>
      {% endif %}
    </div>
  </div>

  <div class="footer-bottom">
    <p class="footer-copyright">&copy; {{ 'now' | date: '%Y' }} Vella. All rights reserved.</p>
    {% if section.settings.show_payment_icons %}
      <div class="footer-payments">
        {% for type in shop.enabled_payment_types %}
          {{ type | payment_type_svg_tag }}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "link_list",
      "id": "shop_menu",
      "label": "Shop menu"
    },
    {
      "type": "link_list",
      "id": "info_menu",
      "label": "Info menu"
    },
    {
      "type": "link_list",
      "id": "legal_menu",
      "label": "Legal menu"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    }
  ]
}
{% endschema %}
