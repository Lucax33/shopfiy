<section class="hero" aria-label="Hero banner">
  {% if section.settings.image %}
    <img class="hero__image" src="{{ section.settings.image | image_url: width: 1920 }}"
         srcset="{{ section.settings.image | image_url: width: 800 }} 800w, {{ section.settings.image | image_url: width: 1200 }} 1200w, {{ section.settings.image | image_url: width: 1920 }} 1920w"
         sizes="100vw" alt="{{ section.settings.image.alt | default: 'VELLA hero' }}" loading="eager" fetchpriority="high">
  {% else %}
    <div class="hero__image" style="background: linear-gradient(135deg, var(--color-espresso) 0%, var(--color-dark-taupe) 100%); width:100%; height:100%; position:absolute;"></div>
  {% endif %}
  <div class="hero__overlay"></div>
  <div class="hero__content animate-in">
    <h1>{{ section.settings.heading | default: 'Quiet Luxury, Everyday.' }}</h1>
    <p>{{ section.settings.subheading | default: 'Curated essentials for the woman who values comfort and elegance.' }}</p>
    {% if section.settings.cta_text != blank %}
      <a href="{{ section.settings.cta_link | default: routes.collections_url }}" class="btn-primary btn-inline">
        {{ section.settings.cta_text | default: 'Shop the Collection' }}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Quiet Luxury, Everyday."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Curated essentials for the woman who values comfort and elegance."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
