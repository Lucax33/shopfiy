<section class="section" aria-label="Shop by category">
  <div class="container">
    <div class="section-header animate-in">
      <span class="section-tag">✦ {{ section.settings.tag | default: 'Collections' }} ✦</span>
      <h2>{{ section.settings.title | default: 'Shop by Mood' }}</h2>
      <div class="gold-line"></div>
    </div>

    <div class="category-grid stagger">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link | default: '#' }}" class="category-card animate-in" {{ block.shopify_attributes }}>
          {% if block.settings.image %}
            <img src="{{ block.settings.image | image_url: width: 800 }}"
                 srcset="{{ block.settings.image | image_url: width: 500 }} 500w, {{ block.settings.image | image_url: width: 800 }} 800w"
                 sizes="(max-width: 767px) 100vw, 50vw"
                 alt="{{ block.settings.title | default: 'Category' }}"
                 width="600" height="450" loading="lazy">
          {% else %}
            <div style="background: linear-gradient(135deg, var(--color-sand) 0%, var(--color-taupe) 100%); width:100%; height:100%; position:absolute;"></div>
          {% endif %}

          <div class="category-card__overlay">
            <h3 class="category-card__title">{{ block.settings.title | default: 'Category' }}</h3>
            <span class="category-card__link">Shop Now →</span>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category Grid",
  "settings": [
    {
      "type": "text",
      "id": "tag",
      "label": "Section tag",
      "default": "Collections"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop by Mood"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Comfort"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Category Grid",
      "blocks": [
        { "type": "category", "settings": { "title": "Comfort" } },
        { "type": "category", "settings": { "title": "Active" } },
        { "type": "category", "settings": { "title": "Sleepwear" } },
        { "type": "category", "settings": { "title": "Essentials" } }
      ]
    }
  ]
}
{% endschema %}
