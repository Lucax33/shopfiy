<section class="faq-section" aria-label="Frequently Asked Questions">
  <div class="section-header animate-in">
    <span class="section-tag">✦ FAQ ✦</span>
    <h1>{{ section.settings.heading | default: 'Frequently Asked Questions' }}</h1>
    <div class="gold-line"></div>
  </div>

  <div class="faq-list animate-in">
    {% for block in section.blocks %}
      <div class="faq-item" {{ block.shopify_attributes }}>
        <button class="faq-item__question" aria-expanded="false">
          <span>{{ block.settings.question }}</span>
          <span class="faq-item__icon">+</span>
        </button>
        <div class="faq-item__answer" role="region">
          <p>{{ block.settings.answer }}</p>
        </div>
      </div>
    {% endfor %}
  </div>

  <div class="faq-cta animate-in">
    <p>Still have questions?</p>
    <a href="/pages/contact" class="btn-secondary btn-inline">Contact Us</a>
  </div>
</section>

{% schema %}
{
  "name": "FAQ Accordion",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How long does shipping take?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Orders are processed within 1-3 business days. Standard delivery takes 7-15 business days depending on your location."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Accordion",
      "blocks": [
        { "type": "faq", "settings": { "question": "How long does shipping take?", "answer": "Orders are processed within 1-3 business days. Standard delivery takes 7-15 business days depending on your location. You'll receive a tracking number via email once your order ships." } },
        { "type": "faq", "settings": { "question": "Is shipping free?", "answer": "Yes! We offer free standard shipping on all orders over $35 within the United States." } },
        { "type": "faq", "settings": { "question": "What is your return policy?", "answer": "We offer a 30-day return policy on all unused items in original packaging. Simply contact us at hello@shopvella.com to initiate a return." } },
        { "type": "faq", "settings": { "question": "How do I find my size?", "answer": "Each product page includes a detailed size guide. We recommend measuring your feet and comparing to our size chart. Our styles tend to run slightly small, so ordering one size up is recommended." } },
        { "type": "faq", "settings": { "question": "What payment methods do you accept?", "answer": "We accept all major credit cards (Visa, Mastercard, American Express), PayPal, Apple Pay, Google Pay, and Shop Pay." } },
        { "type": "faq", "settings": { "question": "Can I change or cancel my order?", "answer": "We process orders quickly! Please contact us within 2 hours of placing your order, and we'll do our best to accommodate changes or cancellations." } },
        { "type": "faq", "settings": { "question": "Do you ship internationally?", "answer": "Currently, we ship within the United States only. International shipping is coming soon — sign up for our newsletter to be the first to know!" } },
        { "type": "faq", "settings": { "question": "Are your products true to color?", "answer": "We do our best to accurately represent the colors of our products. However, slight variations may occur due to monitor settings and lighting conditions." } },
        { "type": "faq", "settings": { "question": "How do I track my order?", "answer": "Once your order ships, you'll receive an email with your tracking number. You can also track your order through the link in your shipping confirmation email." } },
        { "type": "faq", "settings": { "question": "What if I receive a defective item?", "answer": "We're sorry if that happens! Please contact us at hello@shopvella.com with photos of the defect, and we'll send a replacement or issue a full refund right away." } }
      ]
    }
  ]
}
{% endschema %}
