{% comment %} Collection Banner {% endcomment %}
<section class="collection-banner" aria-label="{{ collection.title }}">
  {% if collection.image %}
    <img src="{{ collection.image | image_url: width: 1600 }}" alt="{{ collection.title }}" loading="eager">
  {% else %}
    <div style="background: linear-gradient(135deg, var(--color-espresso), var(--color-dark-taupe)); width:100%; height:100%; position:absolute;"></div>
  {% endif %}
  <div class="collection-banner__overlay"></div>
  <div class="collection-banner__content animate-in">
    <h1>{{ collection.title }}</h1>
    {% if collection.description != blank %}
      <p>{{ collection.description | strip_html | truncate: 120 }}</p>
    {% endif %}
  </div>
</section>

<section class="section">
  <div class="container">
    {% comment %} Toolbar {% endcomment %}
    <div class="collection-toolbar">
      <span style="font-size: var(--text-sm); color: var(--color-text-tertiary);">
        {{ collection.products_count }} {{ collection.products_count | pluralize: 'product', 'products' }}
      </span>
      <div class="collection-toolbar__sort">
        <label for="sort-by" class="visually-hidden">Sort by</label>
        <select id="sort-by" onchange="window.location.href = this.value;">
          {% for option in collection.sort_options %}
            <option value="{{ collection.url }}?sort_by={{ option.value }}"
              {% if collection.sort_by == option.value %}selected{% endif %}>
              {{ option.name }}
            </option>
          {% endfor %}
        </select>
      </div>
    </div>

    {% comment %} Products Grid {% endcomment %}
    {% if collection.products.size > 0 %}
      <div class="product-grid collection-grid stagger">
        {% for product in collection.products %}
          {% render 'product-card', product: product %}
        {% endfor %}
      </div>

      {% comment %} Pagination {% endcomment %}
      {% if paginate.pages > 1 %}
        <div class="load-more">
          {{ paginate | default_pagination }}
        </div>
      {% endif %}
    {% else %}
      <div class="collection-empty">
        <p>No products found in this collection.</p>
        <a href="{{ routes.collections_url }}" class="btn-text" style="margin-top: var(--space-md); display: inline-block;">Browse Collections</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Collection Template",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 24,
      "step": 4,
      "default": 16
    }
  ]
}
{% endschema %}
