<section class="contact-section" aria-label="Contact us">
  <div class="section-header animate-in">
    <span class="section-tag">✦ Get in Touch ✦</span>
    <h1>{{ section.settings.heading | default: "We'd Love to Hear From You" }}</h1>
    <div class="gold-line"></div>
  </div>

  <div class="contact-info animate-in">
    <p>Email us at <a href="mailto:{{ section.settings.email | default: 'hello@shopvella.com' }}">{{ section.settings.email | default: 'hello@shopvella.com' }}</a></p>
  </div>

  {% form 'contact', class: 'contact-form animate-in' %}
    {% if form.posted_successfully? %}
      <p style="color: var(--color-success); text-align: center; font-weight: var(--weight-medium);">✓ Thank you! We'll get back to you shortly.</p>
    {% endif %}

    {% if form.errors %}
      <div style="color: var(--color-sale); margin-bottom: var(--space-md);">
        {{ form.errors | default_errors }}
      </div>
    {% endif %}

    <div>
      <label for="contact-name">Name</label>
      <input type="text" id="contact-name" name="contact[name]" required autocomplete="name">
    </div>
    <div>
      <label for="contact-email">Email</label>
      <input type="email" id="contact-email" name="contact[email]" required autocomplete="email">
    </div>
    <div>
      <label for="contact-subject">Subject</label>
      <input type="text" id="contact-subject" name="contact[subject]">
    </div>
    <div>
      <label for="contact-message">Message</label>
      <textarea id="contact-message" name="contact[body]" rows="6" required></textarea>
    </div>
    <button type="submit" class="btn-primary">Send Message</button>
  {% endform %}

  <p class="contact-note animate-in">Response time: within 24 hours on business days</p>
</section>

{% schema %}
{
  "name": "Contact Form",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "We'd Love to Hear From You"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Contact email",
      "default": "hello@shopvella.com"
    }
  ],
  "presets": [
    {
      "name": "Contact Form"
    }
  ]
}
{% endschema %}
