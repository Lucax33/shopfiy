{% comment %}
    Renders an icon from SVG collection
    Accepts:
    - name: {String} Icon name (cart, search, account, etc.)
    Usage:
    {% render 'icon', name: 'cart' %}
{% endcomment %}

{% case name %}
  {% when 'cart' %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="24" height="24">
      <path d="M6 6h15l-1.5 9H7.5L6 6z"/><circle cx="9" cy="20" r="1"/><circle cx="18" cy="20" r="1"/>
    </svg>
  {% when 'search' %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="24" height="24">
      <circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="21" y2="21"/>
    </svg>
  {% when 'account' %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="24" height="24">
      <circle cx="12" cy="8" r="4"/><path d="M4 21v-1a6 6 0 0 1 12 0v1"/>
    </svg>
  {% when 'instagram' %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="24" height="24">
      <rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/>
    </svg>
  {% when 'tiktok' %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="24" height="24">
      <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/>
    </svg>
  {% when 'pinterest' %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="24" height="24">
      <circle cx="12" cy="12" r="10"/><path d="M8 21c1-3 2-6 3-8 .5-1 1.5-2 3-2s2 1 2 2.5c0 2-1 3.5-1 5s1 2 2 2"/>
    </svg>
{% endcase %}
